@using ServiceBooking.Application.ViewModels.Booking
@model ServiceResponse
@{
    ViewData["Title"] = $"تفاصيل: {Model.Name}";
    var bookings = ViewBag.ServiceBookings as IEnumerable<BookingResponse> ?? [];
}

<div class="container">
    <div class="row">
        <!-- Service Info -->
        <div class="col-lg-5 mb-4">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-info-circle"></i>
                        معلومات الخدمة
                    </h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        <div class="stat-icon blue mx-auto mb-3" style="width:80px;height:80px;font-size:2rem;">
                            <i class="bi bi-droplet"></i>
                        </div>
                        <h4 class="text-primary fw-bold">@Model.Name</h4>
                    </div>

                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between">
                            <span><i class="bi bi-cash-stack me-2 text-success"></i>السعر</span>
                            <span class="fw-bold">@Model.Price.ToString("C", new
                                                                                                System.Globalization.CultureInfo("ar-EG"))</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between">
                                <span><i class="bi bi-clock me-2 text-warning"></i>المدة</span>
                                <span class="fw-bold">@Model.Duration.ToString(@"h\:mm") ساعة</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between">
                                <span><i class="bi bi-calendar-check me-2 text-info"></i>عدد الحجوزات</span>
                                <span class="badge bg-primary">@Model.BookingsCount</span>
                            </li>
                        </ul>

                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <div class="mt-3">
                                <h6 class="text-muted">الوصف:</h6>
                                <p class="text-muted">@Model.Description</p>
                            </div>
                        }

                        <div class="d-flex gap-2 mt-4">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning w-100">
                                <i class="bi bi-pencil"></i> تعديل
                            </a>
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger w-100">
                                <i class="bi bi-trash"></i> حذف
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bookings List -->
            <div class="col-lg-7">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-calendar3"></i>
                            الحجوزات
                        </h5>
                        <span class="badge bg-light text-dark">@bookings.Count() حجز</span>
                    </div>
                    <div class="card-body p-0">
                        @if (bookings.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>العميل</th>
                                            <th>التاريخ</th>
                                            <th>الوقت</th>
                                            <th>السيارة</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var booking in bookings)
                                        {
                                            <tr>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <div class="bg-light rounded-circle p-2 me-2">
                                                            <i class="bi bi-person"></i>
                                                        </div>
                                                        <div>
                                                            <div class="fw-bold">@booking.ClientName</div>
                                                            <small class="text-muted">@booking.ClientPhone</small>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>@booking.BookingDate.ToString("yyyy/MM/dd")</td>
                                                <td>@booking.BookingTime.ToString(@"hh\:mm")</td>
                                                <td>@booking.ClientCarType</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="empty-state">
                                <i class="bi bi-calendar-x"></i>
                                <p>لا توجد حجوزات لهذه الخدمة</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <a asp-action="Index" class="btn btn-outline-primary">
                <i class="bi bi-arrow-right"></i> العودة للقائمة
            </a>
        </div>
    </div>