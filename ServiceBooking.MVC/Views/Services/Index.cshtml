@model List<ServiceResponse>
@{
    ViewBag.Title = "الخدمات";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="page-title">
            <i class="bi bi-grid-3x3-gap"></i>
            الخدمات المتاحة
        </h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i>
            إضافة خدمة
        </a>
    </div>

    <div class="row g-4">
        @if (!Model.Any())
        {
            <p class="text-muted mb-3">لا يوجد خدمات حاليا, يمكنك إنشاء خدمة جديدة</p>
        }
                        
        @foreach (var service in Model)
        {
            <div class="col-md-6 col-lg-4 animate-fade-in">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="card-title fw-bold text-primary mb-0">@service.Name</h5>
                            <span class="badge bg-success">@service.Price.ToEGP()</span>
                        </div>
                        
                        <p class="text-muted mb-3">@(service.Description ?? "لا يوجد وصف")</p>
                        
                        <div class="d-flex align-items-center text-muted mb-3">
                            <i class="bi bi-clock me-2"></i>
                            <span>@service.Duration.ToString(@"h\:mm") @(service.Duration.TotalMinutes> 59? "ساعة": "دقيقة")</span>
                        </div>
                        
                        <div class="d-flex align-items-center text-muted mb-3">
                            <i class="bi bi-calendar-check me-2"></i>
                            <span>@service.BookingsCount حجز</span>
                        </div>
                        
                        <div class="d-flex gap-2 mt-auto">
                            <a asp-action="Details" asp-route-id="@service.Id" class="btn btn-outline-success btn-sm">
                                <i class="bi-eye"></i> عرض
                            </a>
                            <a asp-action="Edit" asp-route-id="@service.Id" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil"></i> تعديل
                            </a>
                            <a asp-action="Delete" asp-route-id="@service.Id"  class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i> حذف
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    
    </div>
</div>
